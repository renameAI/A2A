# 이 파일을 .env로 복사하고 값을 채우세요. .env는 절대 커밋하지 마세요 (SEC-01).
# 키가 노출됐다면 즉시 폐기·재발급하세요 (SEC-02).

# LLM 프로바이더 고정 (friendli | local | anthropic | mock) — 기본 friendli(K-EXAONE)
LLM_PROVIDER=friendli

# K-EXAONE (Friendli dedicated) — 소버린 트랙 (LLM_PROVIDER=friendli)
FRIENDLI_TOKEN=
FRIENDLI_ENDPOINT_ID=

# 로컬/저사양 모델 — 오프라인 실행 (LLM_PROVIDER=local)
# Ollama 예시: `ollama run exaone3.5:7.8b` 후 아래 그대로 사용 (토큰 불필요)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1/chat/completions
LOCAL_LLM_MODEL=exaone3.5:7.8b
LOCAL_LLM_TOKEN=

# Anthropic — 대안 어댑터 (LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# LLM 호출 타임아웃(초) — reasoning 모델 대비
LLM_TIMEOUT=300

# 인스타그램 수집 (Apify — 계약된 서드파티 경유, ING-08)
APIFY_TOKEN=

# 수집 타임아웃 (초)
INGEST_FETCH_TIMEOUT=15

# 질문 위치 탐지 (bbox) — 엑사원 질문을 IR덱 페이지에 핀 꽂는 비전 모델.
# 텍스트 추출(LLM_PROVIDER)과 완전히 독립 — 키만 넣으면 켜진다. 없으면 기능 자체가 꺼진다.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# judge 자기일관성 투표 (FORMALIZATION.md L2/L3) — k-표본 다수결.
# 기본 1 = off(비용·지연 3배 방지). k>1이면 범주형 결정을 다수결하고 일치율을 계측,
# 일치율<임계면 needs_human=True + 자동추천을 hold로 캡(L3 하드 게이트).
JUDGE_SAMPLES=1
JUDGE_AGREEMENT_THRESHOLD=0.6

# VLM 전송 계층 예산 — 배치·사이즈·토큰 상한 (기본값으로 충분, 필요 시만 조정)
VISION_PAGES_PER_CALL=4        # 호출당 페이지 수 상한 (배치 — 질문 프롬프트 중복 절감)
VISION_BATCH_BYTES=3145728     # 배치당 이미지 총량 상한 (3MB)
VISION_TOKEN_BUDGET=300000     # 온보딩 1회당 VLM 토큰 예산 (usageMetadata 실측 누적)
VISION_JPEG_QUALITY=80         # 전송용 JPEG 품질 (PNG/JPEG 중 작은 쪽 자동 선택)
