# 이 파일을 .env로 복사하고 값을 채우세요. .env는 절대 커밋하지 마세요 (SEC-01).
# 키가 노출됐다면 즉시 폐기·재발급하세요 (SEC-02).

# LLM 프로바이더 고정 (friendli | local | anthropic | mock) — 기본 friendli(K-EXAONE)
LLM_PROVIDER=friendli

# K-EXAONE (Friendli dedicated) — 소버린 트랙 (LLM_PROVIDER=friendli)
FRIENDLI_TOKEN=
FRIENDLI_ENDPOINT_ID=

# 로컬/저사양 모델 — 오프라인 실행 (LLM_PROVIDER=local)
# Ollama 예시: `ollama run exaone3.5:7.8b` 후 아래 그대로 사용 (토큰 불필요)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1/chat/completions
LOCAL_LLM_MODEL=exaone3.5:7.8b
LOCAL_LLM_TOKEN=

# Anthropic — 대안 어댑터 (LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# LLM 호출 타임아웃(초) — reasoning 모델 대비
LLM_TIMEOUT=300

# 인스타그램 수집 (Apify — 계약된 서드파티 경유, ING-08)
APIFY_TOKEN=

# 수집 타임아웃 (초)
INGEST_FETCH_TIMEOUT=15
